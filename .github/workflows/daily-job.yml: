name: Daily Article Generation

on:
  schedule:
    - cron: '0 6 * * *'  # This will run every day at 6 AM UTC
  workflow_dispatch:  # Allows manual trigger if needed

jobs:
  generate-articles:
    runs-on: ubuntu-latest  # Run on the latest Ubuntu

    steps:
    - name: Checkout repository
      uses: actions/checkout@v2

    - name: Set up Node.js
      uses: actions/setup-node@v2
      with:
        node-version: '16'

    - name: Install dependencies
      run: npm install  # Install any dependencies (if applicable)

    - name: Run article generation script
      run: |
        node generateSkyscannerArticles3.js 10  # Adjust this number as needed

    - name: Check for changes and commit generated articles
      run: |
        git config --global user.name 'GitHub Actions'
        git config --global user.email 'actions@github.com'

        # Check if there are any changes in the generated articles folder
        git status
        if [[ $(git status --porcelain) ]]; then
          git add generated-articles/
          git commit -m "Automated article generation"
          git push
        else
          echo "No changes to commit"
        fi
