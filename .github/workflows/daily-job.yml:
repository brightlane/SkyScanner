name: Daily Article Generation

on:
  schedule:
    - cron: '0 6 * * *'  # Runs every day at 6 AM UTC (adjust this to your preferred time)
  workflow_dispatch:  # Allows manual trigger

jobs:
  generate-articles:
    runs-on: ubuntu-latest  # Run on the latest Ubuntu image

    steps:
    # Step 1: Checkout the repository to get access to the code
    - name: Checkout repository
      uses: actions/checkout@v2

    # Step 2: Set up Node.js environment
    - name: Set up Node.js
      uses: actions/setup-node@v2
      with:
        node-version: '16'  # Specify the version of Node.js you want to use

    # Step 3: Install dependencies (if any)
    - name: Install dependencies
      run: npm install  # Only run this if you have dependencies like 'package.json'

    # Step 4: Run article generation script
    - name: Run article generation script
      run: |
        node generateArticles.js 10  # Change the number as needed (e.g., generate 10 articles)

    # Step 5: Check for changes and commit generated articles
    - name: Check for changes and commit generated articles
      run: |
        git config --global user.name 'GitHub Actions'
        git config --global user.email 'actions@github.com'

        # Check if there are any changes in the generated articles directory
        git status

        # If there are changes (new or modified files), commit and push them
        if [[ $(git status --porcelain) ]]; then
          echo "Changes detected, committing..."
          git add generated-articles/
          git commit -m "Automated article generation"
          git push
        else
          echo "No changes to commit"
        fi
