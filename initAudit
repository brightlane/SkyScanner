<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>System Initialization & Audit | StadiumStay 2026</title>
    <script src="generate.js"></script>
    <style>
        :root { --terminal-green: #00ff41; --dark-bg: #0d0d0d; }
        body { background: var(--dark-bg); color: var(--terminal-green); font-family: 'Courier New', Courier, monospace; padding: 40px; line-height: 1.4; }
        .monitor { max-width: 800px; margin: 0 auto; border: 1px solid #333; padding: 20px; border-radius: 8px; box-shadow: 0 0 20px rgba(0,255,65,0.1); }
        .line { margin-bottom: 10px; display: block; overflow: hidden; white-space: nowrap; border-right: .15em solid var(--terminal-green); animation: typing 3.5s steps(40, end), blink-caret .75s step-end infinite; }
        .log-entry { color: #888; font-size: 0.8rem; margin-top: 5px; }
        .stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 30px; border-top: 1px solid #333; padding-top: 20px; }
        .stat-box { border: 1px dashed #333; padding: 15px; text-align: center; }
        .stat-val { font-size: 1.5rem; font-weight: bold; color: white; }
        .btn-portal { display: block; text-align: center; background: var(--terminal-green); color: black; padding: 15px; margin-top: 30px; text-decoration: none; font-weight: bold; text-transform: uppercase; }
        @keyframes typing { from { width: 0 } to { width: 100% } }
        @keyframes blink-caret { from, to { border-color: transparent } 50% { border-color: var(--terminal-green); } }
    </style>
</head>
<body>

<div class="monitor">
    <span class="line">> INITIALIZING GLOBAL AUDIT...</span>
    <span class="line">> SYNCING SKYSCANNER API NODES... [OK]</span>
    <span class="line">> VERIFYING 2026 STADIUM INVENTORY... [100%]</span>
    
    <div id="live-logs">
        </div>

    <div class="stat-grid">
        <div class="stat-box">
            <div class="stat-val" id="total-routes">500+</div>
            <div class="log-entry">Active Routes Audited</div>
        </div>
        <div class="stat-box">
            <div class="stat-val" id="sync-status">ACTIVE</div>
            <div class="log-entry">Affiliate Node 1166692</div>
        </div>
    </div>

    <a href="index.html" class="btn-portal sky-link">Access Verified Search Portal</a>
</div>

<script>
    const logs = [
        "Analyzing MetLife Stadium benchmark...",
        "Scrubbing 'Everywhere' inventory for price gaps...",
        "Updating Bali Wellness retreat currency rates...",
        "Applying Secret #6 Authority Anchor...",
        "Audit Complete: System 100% Operational."
    ];

    const logBox = document.getElementById('live-logs');
    let i = 0;

    function addLog() {
        if (i < logs.length) {
            const entry = document.createElement('div');
            entry.className = 'log-entry';
            entry.innerText = `[${new Date().toLocaleTimeString()}] ${logs[i]}`;
            logBox.appendChild(entry);
            i++;
            setTimeout(addLog, 1200);
        }
    }

    document.addEventListener('DOMContentLoaded', addLog);
</script>

</body>
</html>
